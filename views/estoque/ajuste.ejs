<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ajuste de Estoque - Nevada & Montreal ERP</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="app-layout">
    <%- include('../partials/sidebar') %>
    <div class="main-content">
        <%- include('../partials/header') %>
        <div class="page-content">

            <% if (typeof mensagem !== 'undefined' && mensagem) { %>
                <div class="alert alert-success" data-dismiss><%= mensagem %></div>
            <% } %>
            <% if (typeof erro !== 'undefined' && erro) { %>
                <div class="alert alert-danger" data-dismiss><%= erro %></div>
            <% } %>

            <div class="breadcrumb">
                <a href="/estoque">Estoque</a> <span>/</span> <span>Ajuste</span>
            </div>

            <div class="page-header">
                <h1>Ajuste de Estoque</h1>
                <a href="/estoque" class="btn btn-secondary">Voltar</a>
            </div>

            <div class="card" style="max-width:600px;">
                <div class="card-header"><h3>Ajustar Quantidade</h3></div>
                <div class="card-body">
                    <form method="POST" action="/estoque/ajuste">
                        <div class="form-group">
                            <label>Produto *</label>
                            <select name="produto_id" id="produtoSelect" class="form-control" required onchange="atualizarQtdAtual()">
                                <option value="">Selecione o produto...</option>
                                <% produtos.forEach(function(p) { %>
                                    <option value="<%= p.id %>" data-qtd="<%= p.quantidade %>">
                                        <%= p.codigo ? p.codigo + ' - ' : '' %><%= p.nome %> (Atual: <%= p.quantidade %>)
                                    </option>
                                <% }); %>
                            </select>
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label>Quantidade Atual</label>
                                <input type="text" id="qtdAtual" class="form-control" readonly style="background:var(--gray-50); font-weight:700; font-size:18px;">
                            </div>
                            <div class="form-group">
                                <label>Nova Quantidade *</label>
                                <input type="number" name="nova_quantidade" id="novaQtd" class="form-control" step="0.01" min="0" required
                                    style="font-weight:700; font-size:18px;" oninput="calcularDiferenca()">
                            </div>
                        </div>

                        <div id="diferencaInfo" style="display:none; margin-bottom:16px; padding:12px; border-radius:var(--radius);"></div>

                        <div class="form-group">
                            <label>Motivo / Observacao</label>
                            <textarea name="observacao" class="form-control" rows="3" placeholder="Descreva o motivo do ajuste..."></textarea>
                        </div>

                        <div class="btn-group">
                            <button type="submit" class="btn btn-warning btn-lg" onclick="return confirm('Confirmar ajuste de estoque?')">Realizar Ajuste</button>
                            <a href="/estoque" class="btn btn-secondary btn-lg">Cancelar</a>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>
<script src="/js/app.js"></script>
<script>
    var produtosEstoque = <%- JSON.stringify(produtos) %>;

    function atualizarQtdAtual() {
        var select = document.getElementById('produtoSelect');
        var option = select.options[select.selectedIndex];
        var qtd = option.getAttribute('data-qtd') || '0';
        document.getElementById('qtdAtual').value = qtd;
        document.getElementById('novaQtd').value = '';
        document.getElementById('diferencaInfo').style.display = 'none';
    }

    function calcularDiferenca() {
        var atual = parseFloat(document.getElementById('qtdAtual').value) || 0;
        var nova = parseFloat(document.getElementById('novaQtd').value) || 0;
        var diff = nova - atual;
        var info = document.getElementById('diferencaInfo');

        if (document.getElementById('novaQtd').value === '') {
            info.style.display = 'none';
            return;
        }

        info.style.display = 'block';
        if (diff > 0) {
            info.style.background = 'var(--success-light)';
            info.style.color = 'var(--success)';
            info.innerHTML = '<strong>+' + diff.toFixed(2) + '</strong> unidade(s) serao adicionadas ao estoque';
        } else if (diff < 0) {
            info.style.background = 'var(--danger-light)';
            info.style.color = 'var(--danger)';
            info.innerHTML = '<strong>' + diff.toFixed(2) + '</strong> unidade(s) serao removidas do estoque';
        } else {
            info.style.background = 'var(--warning-light)';
            info.style.color = 'var(--warning)';
            info.innerHTML = 'Nenhuma alteracao - quantidade permanece a mesma';
        }
    }
</script>
</body>
</html>

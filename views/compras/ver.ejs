<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Compra <%= compra.numero || '#' + compra.id %> - Nevada & Montreal ERP</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="app-layout">
    <%- include('../partials/sidebar') %>
    <div class="main-content">
        <%- include('../partials/header') %>
        <div class="page-content">

            <% if (typeof mensagem !== 'undefined' && mensagem) { %>
                <div class="alert alert-success" data-dismiss><%= mensagem %></div>
            <% } %>
            <% if (typeof erro !== 'undefined' && erro) { %>
                <div class="alert alert-danger" data-dismiss><%= erro %></div>
            <% } %>

            <div class="breadcrumb">
                <a href="/compras">Compras</a> <span>/</span> <span><%= compra.numero || '#' + compra.id %></span>
            </div>

            <div class="page-header">
                <div>
                    <h1>Compra <%= compra.numero || '#' + compra.id %></h1>
                    <div style="margin-top: 4px;">
                        <% if (compra.status === 'recebida') { %>
                            <span class="badge badge-success">Recebida</span>
                        <% } else if (compra.status === 'cancelada') { %>
                            <span class="badge badge-danger">Cancelada</span>
                        <% } else if (compra.status === 'cotacao') { %>
                            <span class="badge badge-info">Cotacao</span>
                        <% } else if (compra.status === 'pedido') { %>
                            <span class="badge badge-warning">Pedido</span>
                        <% } %>
                    </div>
                </div>
                <div class="btn-group">
                    <a href="/compras" class="btn btn-secondary">Voltar</a>
                    <% if (compra.status === 'pedido') { %>
                        <form method="POST" action="/compras/receber/<%= compra.id %>" style="display: inline;">
                            <button type="submit" class="btn btn-success" onclick="return confirm('Confirmar recebimento desta compra?')">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                                Receber Compra
                            </button>
                        </form>
                    <% } %>
                    <% if (compra.status !== 'cancelada' && compra.status !== 'recebida') { %>
                        <a href="/compras/cancelar/<%= compra.id %>" class="btn btn-danger" onclick="return confirm('Cancelar esta compra? Esta acao nao pode ser desfeita.')">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                            Cancelar Compra
                        </a>
                    <% } %>
                </div>
            </div>

            <!-- Info Cards -->
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px;">
                <div class="card">
                    <div class="card-header"><h3>Dados da Compra</h3></div>
                    <div class="card-body">
                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 12px;">
                            <div>
                                <div style="font-size: 12px; color: var(--gray-500); text-transform: uppercase; font-weight: 600; margin-bottom: 2px;">Numero</div>
                                <div style="font-weight: 600;"><%= compra.numero || '#' + compra.id %></div>
                            </div>
                            <div>
                                <div style="font-size: 12px; color: var(--gray-500); text-transform: uppercase; font-weight: 600; margin-bottom: 2px;">Data da Compra</div>
                                <div><%= moment(compra.data_compra).format('DD/MM/YYYY') %></div>
                            </div>
                            <div>
                                <div style="font-size: 12px; color: var(--gray-500); text-transform: uppercase; font-weight: 600; margin-bottom: 2px;">Forma de Pagamento</div>
                                <div><%= compra.forma_pagamento || '-' %></div>
                            </div>
                            <div>
                                <div style="font-size: 12px; color: var(--gray-500); text-transform: uppercase; font-weight: 600; margin-bottom: 2px;">Parcelas</div>
                                <div><%= compra.parcelas || '1' %>x</div>
                            </div>
                            <% if (compra.data_entrega) { %>
                                <div>
                                    <div style="font-size: 12px; color: var(--gray-500); text-transform: uppercase; font-weight: 600; margin-bottom: 2px;">Previsao de Entrega</div>
                                    <div><%= moment(compra.data_entrega).format('DD/MM/YYYY') %></div>
                                </div>
                            <% } %>
                            <% if (compra.usuario_nome) { %>
                                <div>
                                    <div style="font-size: 12px; color: var(--gray-500); text-transform: uppercase; font-weight: 600; margin-bottom: 2px;">Registrado por</div>
                                    <div><%= compra.usuario_nome %></div>
                                </div>
                            <% } %>
                        </div>
                        <% if (compra.observacoes) { %>
                            <div style="margin-top: 12px;">
                                <div style="font-size: 12px; color: var(--gray-500); text-transform: uppercase; font-weight: 600; margin-bottom: 2px;">Observacoes</div>
                                <p style="color: var(--gray-600); white-space: pre-wrap; margin: 0;"><%= compra.observacoes %></p>
                            </div>
                        <% } %>
                        <% if (compra.nfe_chave) { %>
                            <div style="margin-top: 12px;">
                                <div style="font-size: 12px; color: var(--gray-500); text-transform: uppercase; font-weight: 600; margin-bottom: 2px;">Chave NF-e</div>
                                <div style="font-family: monospace; font-size: 12px; word-break: break-all;"><%= compra.nfe_chave %></div>
                            </div>
                        <% } %>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header"><h3>Fornecedor</h3></div>
                    <div class="card-body">
                        <div style="font-weight: 600; font-size: 16px; margin-bottom: 4px;">
                            <%= compra.fornecedor_nome || '-' %>
                        </div>
                        <% if (compra.fornecedor_fantasia) { %>
                            <div style="color: var(--gray-500); margin-bottom: 8px;"><%= compra.fornecedor_fantasia %></div>
                        <% } %>
                        <% if (compra.fornecedor_cnpj) { %>
                            <div style="font-size: 13px; color: var(--gray-600);">CNPJ: <%= compra.fornecedor_cnpj %></div>
                        <% } %>
                        <% if (compra.fornecedor_telefone) { %>
                            <div style="font-size: 13px; color: var(--gray-600);">Tel: <%= compra.fornecedor_telefone %></div>
                        <% } %>
                    </div>
                </div>
            </div>

            <!-- Itens da Compra -->
            <div class="card" style="margin-bottom: 16px;">
                <div class="card-header">
                    <h3>Itens da Compra</h3>
                    <span style="font-size: 13px; color: var(--gray-500);"><%= itens.length %> ite<%= itens.length !== 1 ? 'ns' : 'm' %></span>
                </div>
                <div class="table-container">
                    <table>
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Codigo</th>
                                <th>Produto</th>
                                <th style="text-align: right;">Qtd</th>
                                <th style="text-align: right;">Preco Unit.</th>
                                <th style="text-align: right;">Desconto</th>
                                <th style="text-align: right;">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% itens.forEach(function(item, idx) { %>
                                <tr>
                                    <td><%= idx + 1 %></td>
                                    <td><%= item.produto_codigo || '-' %></td>
                                    <td><strong><%= item.produto_nome %></strong></td>
                                    <td style="text-align: right;"><%= formatNumber(item.quantidade) %></td>
                                    <td style="text-align: right;"><%= formatMoney(item.preco_unitario) %></td>
                                    <td style="text-align: right;"><%= formatMoney(item.desconto || 0) %></td>
                                    <td style="text-align: right;"><strong><%= formatMoney(item.total) %></strong></td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Totais -->
            <div class="card">
                <div class="card-body">
                    <div style="max-width: 400px; margin-left: auto;">
                        <div style="display: flex; justify-content: space-between; padding: 8px 0; font-size: 14px;">
                            <span style="color: var(--gray-600);">Subtotal:</span>
                            <span><%= formatMoney(compra.subtotal) %></span>
                        </div>
                        <% if (compra.frete > 0) { %>
                            <div style="display: flex; justify-content: space-between; padding: 8px 0; font-size: 14px;">
                                <span style="color: var(--gray-600);">Frete:</span>
                                <span><%= formatMoney(compra.frete) %></span>
                            </div>
                        <% } %>
                        <% if (compra.desconto > 0) { %>
                            <div style="display: flex; justify-content: space-between; padding: 8px 0; font-size: 14px; color: var(--danger);">
                                <span>Desconto:</span>
                                <span>- <%= formatMoney(compra.desconto) %></span>
                            </div>
                        <% } %>
                        <hr style="border: none; border-top: 2px solid var(--gray-200); margin: 4px 0;">
                        <div style="display: flex; justify-content: space-between; padding: 8px 0;">
                            <span style="font-weight: 700; font-size: 18px; color: var(--dark);">Total:</span>
                            <span style="font-weight: 700; font-size: 24px; color: var(--primary);"><%= formatMoney(compra.total) %></span>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>
<script src="/js/app.js"></script>
</body>
</html>

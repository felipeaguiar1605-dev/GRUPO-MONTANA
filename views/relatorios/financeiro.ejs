<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Relatorio Financeiro - Nevada & Montreal ERP</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="app-layout">
    <%- include('../partials/sidebar') %>
    <div class="main-content">
        <%- include('../partials/header') %>
        <div class="page-content">

            <% if (typeof mensagem !== 'undefined' && mensagem) { %>
                <div class="alert alert-success" data-dismiss><%= mensagem %></div>
            <% } %>
            <% if (typeof erro !== 'undefined' && erro) { %>
                <div class="alert alert-danger" data-dismiss><%= erro %></div>
            <% } %>

            <div class="breadcrumb">
                <a href="/relatorios">Relatorios</a> <span>/</span> <span>Financeiro</span>
            </div>

            <div class="page-header">
                <h1>Relatorio Financeiro</h1>
                <a href="/relatorios" class="btn btn-secondary">Voltar</a>
            </div>

            <!-- Resumo -->
            <div class="stats-grid" style="grid-template-columns: repeat(3, 1fr);">
                <div class="stat-card">
                    <div class="stat-icon green">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
                    </div>
                    <div class="stat-info">
                        <h4>Total Receitas</h4>
                        <div class="stat-value" style="color: var(--success);"><%= formatMoney(resumo.total_receitas) %></div>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon red">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 18 13.5 8.5 8.5 13.5 1 6"/><polyline points="17 18 23 18 23 12"/></svg>
                    </div>
                    <div class="stat-info">
                        <h4>Total Despesas</h4>
                        <div class="stat-value" style="color: var(--danger);"><%= formatMoney(resumo.total_despesas) %></div>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon <%= resumo.lucro >= 0 ? 'blue' : 'red' %>">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
                    </div>
                    <div class="stat-info">
                        <h4>Lucro</h4>
                        <div class="stat-value" style="color: <%= resumo.lucro >= 0 ? 'var(--success)' : 'var(--danger)' %>;"><%= formatMoney(resumo.lucro) %></div>
                    </div>
                </div>
            </div>

            <!-- DRE Simplificado -->
            <div class="card" style="margin-bottom:16px;">
                <div class="card-header">
                    <h3>DRE Simplificado (por Mes)</h3>
                </div>
                <div class="table-container">
                    <table>
                        <thead>
                            <tr>
                                <th>Mes</th>
                                <th>Receitas</th>
                                <th>Despesas</th>
                                <th>Lucro/Prejuizo</th>
                                <th>Margem</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (typeof dre !== 'undefined' && dre.length > 0) { %>
                                <% dre.forEach(function(d) { %>
                                    <%
                                        var lucro = (d.receitas || 0) - (d.despesas || 0);
                                        var margem = d.receitas > 0 ? ((lucro / d.receitas) * 100).toFixed(1) : '0.0';
                                    %>
                                    <tr>
                                        <td><strong><%= d.mes %></strong></td>
                                        <td style="color:var(--success);"><%= formatMoney(d.receitas) %></td>
                                        <td style="color:var(--danger);"><%= formatMoney(d.despesas) %></td>
                                        <td><strong style="color: <%= lucro >= 0 ? 'var(--success)' : 'var(--danger)' %>;"><%= formatMoney(lucro) %></strong></td>
                                        <td><%= margem %>%</td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr>
                                    <td colspan="5" style="text-align:center; color:var(--gray-400); padding:24px;">
                                        Nenhum dado encontrado
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Projecao -->
            <div class="card">
                <div class="card-header">
                    <h3>Projecao</h3>
                </div>
                <div class="table-container">
                    <table>
                        <thead>
                            <tr>
                                <th>Mes</th>
                                <th>Receitas Previstas</th>
                                <th>Despesas Previstas</th>
                                <th>Saldo Previsto</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (typeof projecao !== 'undefined' && projecao.length > 0) { %>
                                <% projecao.forEach(function(p) { %>
                                    <%
                                        var saldoPrev = (p.receitas_previstas || 0) - (p.despesas_previstas || 0);
                                    %>
                                    <tr>
                                        <td><strong><%= p.mes %></strong></td>
                                        <td style="color:var(--success);"><%= formatMoney(p.receitas_previstas) %></td>
                                        <td style="color:var(--danger);"><%= formatMoney(p.despesas_previstas) %></td>
                                        <td><strong style="color: <%= saldoPrev >= 0 ? 'var(--success)' : 'var(--danger)' %>;"><%= formatMoney(saldoPrev) %></strong></td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr>
                                    <td colspan="4" style="text-align:center; color:var(--gray-400); padding:24px;">
                                        Nenhuma projecao disponivel
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>

        </div>
    </div>
</div>
<script src="/js/app.js"></script>
</body>
</html>

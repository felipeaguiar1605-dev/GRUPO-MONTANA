<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Relatorio de Vendas - Nevada & Montreal ERP</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="app-layout">
    <%- include('../partials/sidebar') %>
    <div class="main-content">
        <%- include('../partials/header') %>
        <div class="page-content">

            <% if (typeof mensagem !== 'undefined' && mensagem) { %>
                <div class="alert alert-success" data-dismiss><%= mensagem %></div>
            <% } %>
            <% if (typeof erro !== 'undefined' && erro) { %>
                <div class="alert alert-danger" data-dismiss><%= erro %></div>
            <% } %>

            <div class="breadcrumb">
                <a href="/relatorios">Relatorios</a> <span>/</span> <span>Vendas</span>
            </div>

            <div class="page-header">
                <h1>Relatorio de Vendas</h1>
                <a href="/relatorios" class="btn btn-secondary">Voltar</a>
            </div>

            <!-- Filtros -->
            <div class="card" style="margin-bottom:16px;">
                <div class="card-body">
                    <form method="GET" action="/relatorios/vendas" class="filters">
                        <div class="form-group" style="margin-bottom:0; min-width:140px;">
                            <label>Data Inicio</label>
                            <input type="date" name="data_inicio" class="form-control" value="<%= filtros.data_inicio || '' %>">
                        </div>
                        <div class="form-group" style="margin-bottom:0; min-width:140px;">
                            <label>Data Fim</label>
                            <input type="date" name="data_fim" class="form-control" value="<%= filtros.data_fim || '' %>">
                        </div>
                        <div class="form-group" style="margin-bottom:0; align-self:flex-end;">
                            <button type="submit" class="btn btn-primary">Filtrar</button>
                            <a href="/relatorios/vendas" class="btn btn-secondary">Limpar</a>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Resumo -->
            <div class="stats-grid" style="grid-template-columns: repeat(3, 1fr);">
                <div class="stat-card">
                    <div class="stat-icon blue">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
                    </div>
                    <div class="stat-info">
                        <h4>Total Vendas</h4>
                        <div class="stat-value"><%= formatMoney(resumo.total_vendas) %></div>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon green">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/></svg>
                    </div>
                    <div class="stat-info">
                        <h4>Qtd Vendas</h4>
                        <div class="stat-value"><%= formatNumber(resumo.quantidade_vendas) %></div>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon cyan">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
                    </div>
                    <div class="stat-info">
                        <h4>Ticket Medio</h4>
                        <div class="stat-value"><%= formatMoney(resumo.ticket_medio) %></div>
                    </div>
                </div>
            </div>

            <!-- Detalhes -->
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px;">

                <!-- Por Forma de Pagamento -->
                <div class="card">
                    <div class="card-header">
                        <h3>Por Forma de Pagamento</h3>
                    </div>
                    <div class="table-container">
                        <table>
                            <thead>
                                <tr>
                                    <th>Forma de Pagamento</th>
                                    <th>Quantidade</th>
                                    <th>Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (porFormaPagamento.length === 0) { %>
                                    <tr>
                                        <td colspan="3" style="text-align:center; color:var(--gray-400); padding:24px;">
                                            Nenhum dado encontrado
                                        </td>
                                    </tr>
                                <% } else { %>
                                    <% porFormaPagamento.forEach(function(fp) { %>
                                        <tr>
                                            <td><strong><%= fp.forma_pagamento || 'Nao informado' %></strong></td>
                                            <td><%= fp.quantidade %></td>
                                            <td><strong><%= formatMoney(fp.total) %></strong></td>
                                        </tr>
                                    <% }); %>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Por Vendedor -->
                <div class="card">
                    <div class="card-header">
                        <h3>Por Vendedor</h3>
                    </div>
                    <div class="table-container">
                        <table>
                            <thead>
                                <tr>
                                    <th>Vendedor</th>
                                    <th>Quantidade</th>
                                    <th>Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (porVendedor.length === 0) { %>
                                    <tr>
                                        <td colspan="3" style="text-align:center; color:var(--gray-400); padding:24px;">
                                            Nenhum dado encontrado
                                        </td>
                                    </tr>
                                <% } else { %>
                                    <% porVendedor.forEach(function(v) { %>
                                        <tr>
                                            <td><strong><%= v.vendedor_nome || 'Sem vendedor' %></strong></td>
                                            <td><%= v.quantidade %></td>
                                            <td><strong><%= formatMoney(v.total) %></strong></td>
                                        </tr>
                                    <% }); %>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>

            </div>

        </div>
    </div>
</div>
<script src="/js/app.js"></script>
</body>
</html>

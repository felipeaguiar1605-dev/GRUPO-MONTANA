<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Relatorio de Comissoes - Nevada & Montreal ERP</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="app-layout">
    <%- include('../partials/sidebar') %>
    <div class="main-content">
        <%- include('../partials/header') %>
        <div class="page-content">
            <div class="page-header">
                <h1>Relatorio de Comissoes</h1>
                <a href="/relatorios" class="btn btn-secondary">Voltar</a>
            </div>

            <div class="card" style="margin-bottom: 20px;">
                <div class="card-body">
                    <form method="GET" action="/relatorios/comissoes" class="filters">
                        <div class="form-group" style="margin-bottom:0;">
                            <label style="font-size:12px;">Vendedor</label>
                            <select name="vendedor_id" class="form-control">
                                <option value="">Todos</option>
                                <% if (typeof vendedores !== 'undefined') { %>
                                    <% vendedores.forEach(function(v) { %>
                                        <option value="<%= v.id %>" <%= (typeof filtros !== 'undefined' && filtros.vendedor_id == v.id) ? 'selected' : '' %>><%= v.nome %></option>
                                    <% }); %>
                                <% } %>
                            </select>
                        </div>
                        <div class="form-group" style="margin-bottom:0;">
                            <label style="font-size:12px;">De</label>
                            <input type="date" name="data_inicio" class="form-control" value="<%= typeof filtros !== 'undefined' ? filtros.data_inicio || '' : '' %>">
                        </div>
                        <div class="form-group" style="margin-bottom:0;">
                            <label style="font-size:12px;">Ate</label>
                            <input type="date" name="data_fim" class="form-control" value="<%= typeof filtros !== 'undefined' ? filtros.data_fim || '' : '' %>">
                        </div>
                        <button type="submit" class="btn btn-primary" style="align-self:flex-end;">Filtrar</button>
                    </form>
                </div>
            </div>

            <% if (typeof comissoes !== 'undefined' && comissoes.length > 0) { %>
            <div class="card">
                <div class="card-header"><h3>Comissoes por Vendedor</h3></div>
                <div class="card-body table-container">
                    <table>
                        <thead>
                            <tr>
                                <th>Vendedor</th>
                                <th>Total Vendas</th>
                                <th>Total Comissao</th>
                                <th>Pagas</th>
                                <th>Pendentes</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% comissoes.forEach(function(item) { %>
                            <tr>
                                <td><strong><%= item.vendedor_nome %></strong></td>
                                <td><%= formatMoney(item.total_vendas) %></td>
                                <td><%= formatMoney(item.total_comissao) %></td>
                                <td><span class="badge badge-success"><%= formatMoney(item.comissoes_pagas) %></span></td>
                                <td><span class="badge badge-warning"><%= formatMoney(item.comissoes_pendentes) %></span></td>
                            </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            </div>
            <% } else { %>
            <div class="card">
                <div class="card-body">
                    <div class="empty-state">
                        <h3>Sem dados de comissoes</h3>
                        <p>Nenhuma comissao encontrada no periodo selecionado.</p>
                    </div>
                </div>
            </div>
            <% } %>
        </div>
    </div>
</div>
<script src="/js/app.js"></script>
</body>
</html>

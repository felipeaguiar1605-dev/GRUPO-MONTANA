<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Relatorio de Comissoes - Nevada & Montreal ERP</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="app-layout">
    <%- include('../partials/sidebar') %>
    <div class="main-content">
        <%- include('../partials/header') %>
        <div class="page-content">

            <% if (typeof mensagem !== 'undefined' && mensagem) { %>
                <div class="alert alert-success" data-dismiss><%= mensagem %></div>
            <% } %>
            <% if (typeof erro !== 'undefined' && erro) { %>
                <div class="alert alert-danger" data-dismiss><%= erro %></div>
            <% } %>

            <div class="breadcrumb">
                <a href="/relatorios">Relatorios</a> <span>/</span> <span>Comissoes</span>
            </div>

            <div class="page-header">
                <h1>Relatorio de Comissoes</h1>
                <a href="/relatorios" class="btn btn-secondary">Voltar</a>
            </div>

            <!-- Filtros -->
            <div class="card" style="margin-bottom:16px;">
                <div class="card-body">
                    <form method="GET" action="/relatorios/comissoes" class="filters">
                        <div class="form-group" style="margin-bottom:0; min-width:200px;">
                            <label>Vendedor</label>
                            <select name="vendedor_id" class="form-control">
                                <option value="">Todos</option>
                                <% vendedores.forEach(function(v) { %>
                                    <option value="<%= v.id %>" <%= filtros.vendedor_id == v.id ? 'selected' : '' %>><%= v.nome %></option>
                                <% }); %>
                            </select>
                        </div>
                        <div class="form-group" style="margin-bottom:0; min-width:140px;">
                            <label>Data Inicio</label>
                            <input type="date" name="data_inicio" class="form-control" value="<%= filtros.data_inicio || '' %>">
                        </div>
                        <div class="form-group" style="margin-bottom:0; min-width:140px;">
                            <label>Data Fim</label>
                            <input type="date" name="data_fim" class="form-control" value="<%= filtros.data_fim || '' %>">
                        </div>
                        <div class="form-group" style="margin-bottom:0; align-self:flex-end;">
                            <button type="submit" class="btn btn-primary">Filtrar</button>
                            <a href="/relatorios/comissoes" class="btn btn-secondary">Limpar</a>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Tabela de Comissoes -->
            <div class="card">
                <div class="card-header">
                    <h3>Comissoes por Vendedor</h3>
                </div>
                <div class="table-container">
                    <table>
                        <thead>
                            <tr>
                                <th>Vendedor</th>
                                <th>Total Vendas</th>
                                <th>Total Comissao</th>
                                <th>Comissoes Pagas</th>
                                <th>Comissoes Pendentes</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (comissoes.length === 0) { %>
                                <tr>
                                    <td colspan="5" style="text-align:center; color:var(--gray-400); padding:32px;">
                                        Nenhuma comissao encontrada no periodo
                                    </td>
                                </tr>
                            <% } else { %>
                                <% comissoes.forEach(function(c) { %>
                                    <tr>
                                        <td><strong><%= c.vendedor_nome %></strong></td>
                                        <td><%= formatMoney(c.total_vendas) %></td>
                                        <td><strong><%= formatMoney(c.total_comissao) %></strong></td>
                                        <td><span style="color:var(--success);"><%= formatMoney(c.comissoes_pagas) %></span></td>
                                        <td><span style="color:var(--warning);"><%= formatMoney(c.comissoes_pendentes) %></span></td>
                                    </tr>
                                <% }); %>
                                <tr style="background:var(--gray-50); font-weight:700;">
                                    <td>TOTAL</td>
                                    <td><%= formatMoney(comissoes.reduce(function(sum, c) { return sum + (parseFloat(c.total_vendas) || 0); }, 0)) %></td>
                                    <td><%= formatMoney(comissoes.reduce(function(sum, c) { return sum + (parseFloat(c.total_comissao) || 0); }, 0)) %></td>
                                    <td style="color:var(--success);"><%= formatMoney(comissoes.reduce(function(sum, c) { return sum + (parseFloat(c.comissoes_pagas) || 0); }, 0)) %></td>
                                    <td style="color:var(--warning);"><%= formatMoney(comissoes.reduce(function(sum, c) { return sum + (parseFloat(c.comissoes_pendentes) || 0); }, 0)) %></td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>

        </div>
    </div>
</div>
<script src="/js/app.js"></script>
</body>
</html>

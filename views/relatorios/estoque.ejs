<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Relatorio de Estoque - Nevada & Montreal ERP</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="app-layout">
    <%- include('../partials/sidebar') %>
    <div class="main-content">
        <%- include('../partials/header') %>
        <div class="page-content">

            <% if (typeof mensagem !== 'undefined' && mensagem) { %>
                <div class="alert alert-success" data-dismiss><%= mensagem %></div>
            <% } %>
            <% if (typeof erro !== 'undefined' && erro) { %>
                <div class="alert alert-danger" data-dismiss><%= erro %></div>
            <% } %>

            <div class="breadcrumb">
                <a href="/relatorios">Relatorios</a> <span>/</span> <span>Estoque</span>
            </div>

            <div class="page-header">
                <h1>Relatorio de Estoque</h1>
                <a href="/relatorios" class="btn btn-secondary">Voltar</a>
            </div>

            <!-- Resumo -->
            <div class="stats-grid" style="grid-template-columns: repeat(4, 1fr);">
                <div class="stat-card">
                    <div class="stat-icon blue">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
                    </div>
                    <div class="stat-info">
                        <h4>Valor Total em Estoque</h4>
                        <div class="stat-value"><%= formatMoney(resumo.valor_total_estoque) %></div>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon cyan">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/></svg>
                    </div>
                    <div class="stat-info">
                        <h4>Total de Itens</h4>
                        <div class="stat-value"><%= formatNumber(resumo.total_itens) %></div>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon <%= resumo.abaixo_minimo > 0 ? 'red' : 'green' %>">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                    </div>
                    <div class="stat-info">
                        <h4>Abaixo do Minimo</h4>
                        <div class="stat-value" style="color: var(--danger);"><%= resumo.abaixo_minimo %></div>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon yellow">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                    </div>
                    <div class="stat-info">
                        <h4>Sem Movimento</h4>
                        <div class="stat-value"><%= resumo.sem_movimento %></div>
                    </div>
                </div>
            </div>

            <!-- Tabelas -->
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px;">

                <!-- Itens Abaixo do Minimo -->
                <div class="card">
                    <div class="card-header">
                        <h3>Itens Abaixo do Minimo</h3>
                    </div>
                    <div class="table-container">
                        <table>
                            <thead>
                                <tr>
                                    <th>Produto</th>
                                    <th>Quantidade</th>
                                    <th>Est. Minimo</th>
                                    <th>Diferenca</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (typeof abaixoMinimo !== 'undefined' && abaixoMinimo.length > 0) { %>
                                    <% abaixoMinimo.forEach(function(p) { %>
                                        <tr>
                                            <td><strong><%= p.nome %></strong></td>
                                            <td><strong style="color:var(--danger);"><%= p.quantidade %></strong></td>
                                            <td><%= p.estoque_minimo %></td>
                                            <td><strong style="color:var(--danger);"><%= p.quantidade - p.estoque_minimo %></strong></td>
                                        </tr>
                                    <% }); %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="4" style="text-align:center; color:var(--gray-400); padding:24px;">
                                            Nenhum item abaixo do minimo
                                        </td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Itens Sem Movimento -->
                <div class="card">
                    <div class="card-header">
                        <h3>Itens Sem Movimento</h3>
                    </div>
                    <div class="table-container">
                        <table>
                            <thead>
                                <tr>
                                    <th>Produto</th>
                                    <th>Quantidade</th>
                                    <th>Ultimo Movimento</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (typeof semMovimento !== 'undefined' && semMovimento.length > 0) { %>
                                    <% semMovimento.forEach(function(p) { %>
                                        <tr>
                                            <td><strong><%= p.nome %></strong></td>
                                            <td><%= p.quantidade %></td>
                                            <td><%= p.ultimo_movimento ? moment(p.ultimo_movimento).format('DD/MM/YYYY') : 'Nunca' %></td>
                                        </tr>
                                    <% }); %>
                                <% } else { %>
                                    <tr>
                                        <td colspan="3" style="text-align:center; color:var(--gray-400); padding:24px;">
                                            Todos os itens possuem movimentacao recente
                                        </td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>

            </div>

        </div>
    </div>
</div>
<script src="/js/app.js"></script>
</body>
</html>

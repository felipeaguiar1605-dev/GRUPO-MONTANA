<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Relatorios - Nevada & Montreal ERP</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="app-layout">
    <%- include('../partials/sidebar') %>
    <div class="main-content">
        <%- include('../partials/header') %>
        <div class="page-content">

            <% if (typeof mensagem !== 'undefined' && mensagem) { %>
                <div class="alert alert-success" data-dismiss><%= mensagem %></div>
            <% } %>
            <% if (typeof erro !== 'undefined' && erro) { %>
                <div class="alert alert-danger" data-dismiss><%= erro %></div>
            <% } %>

            <div class="page-header">
                <h1>Relatorios</h1>
            </div>

            <div class="stats-grid" style="grid-template-columns: repeat(4, 1fr);">

                <!-- Vendas -->
                <a href="/relatorios/vendas" class="stat-card" style="text-decoration:none; cursor:pointer; transition: transform 0.2s;">
                    <div class="stat-icon blue">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
                            <path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/>
                        </svg>
                    </div>
                    <div class="stat-info">
                        <h4>Vendas</h4>
                        <div class="stat-change">Relatorio de vendas por periodo, forma de pagamento e vendedor</div>
                    </div>
                </a>

                <!-- Estoque -->
                <a href="/relatorios/estoque" class="stat-card" style="text-decoration:none; cursor:pointer; transition: transform 0.2s;">
                    <div class="stat-icon cyan">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/>
                            <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
                            <line x1="12" y1="22.08" x2="12" y2="12"/>
                        </svg>
                    </div>
                    <div class="stat-info">
                        <h4>Estoque</h4>
                        <div class="stat-change">Posicao de estoque, itens abaixo do minimo e sem movimento</div>
                    </div>
                </a>

                <!-- Financeiro -->
                <a href="/relatorios/financeiro" class="stat-card" style="text-decoration:none; cursor:pointer; transition: transform 0.2s;">
                    <div class="stat-icon green">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="12" y1="1" x2="12" y2="23"/>
                            <path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/>
                        </svg>
                    </div>
                    <div class="stat-info">
                        <h4>Financeiro</h4>
                        <div class="stat-change">DRE simplificado, receitas, despesas e projecao</div>
                    </div>
                </a>

                <!-- Comissoes -->
                <a href="/relatorios/comissoes" class="stat-card" style="text-decoration:none; cursor:pointer; transition: transform 0.2s;">
                    <div class="stat-icon yellow">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4-4v2"/>
                            <circle cx="9" cy="7" r="4"/>
                            <path d="M23 21v-2a4 4 0 00-3-3.87"/>
                            <path d="M16 3.13a4 4 0 010 7.75"/>
                        </svg>
                    </div>
                    <div class="stat-info">
                        <h4>Comissoes</h4>
                        <div class="stat-change">Comissoes por vendedor, valores pagos e pendentes</div>
                    </div>
                </a>

            </div>

        </div>
    </div>
</div>
<script src="/js/app.js"></script>
</body>
</html>

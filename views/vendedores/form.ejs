<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Nevada & Montreal ERP</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<div class="app-layout">
    <%- include('../partials/sidebar') %>
    <div class="main-content">
        <%- include('../partials/header') %>
        <div class="page-content">

            <% if (typeof mensagem !== 'undefined' && mensagem) { %>
                <div class="alert alert-success" data-dismiss><%= mensagem %></div>
            <% } %>
            <% if (typeof erro !== 'undefined' && erro) { %>
                <div class="alert alert-danger" data-dismiss><%= erro %></div>
            <% } %>

            <div class="breadcrumb">
                <a href="/vendedores">Vendedores</a> <span>/</span> <span><%= title %></span>
            </div>

            <div class="page-header">
                <h1><%= title %></h1>
            </div>

            <div class="card">
                <div class="card-body">
                    <form method="POST" action="/vendedores/<%= (typeof vendedor !== 'undefined' && vendedor && vendedor.id) ? 'editar/' + vendedor.id : 'novo' %>">
                        <div class="form-row">
                            <div class="form-group">
                                <label>Nome *</label>
                                <input type="text" name="nome" class="form-control" value="<%= (typeof vendedor !== 'undefined' && vendedor) ? vendedor.nome : '' %>" required>
                            </div>
                            <div class="form-group">
                                <label>CPF</label>
                                <input type="text" name="cpf" class="form-control" value="<%= (typeof vendedor !== 'undefined' && vendedor) ? (vendedor.cpf || '') : '' %>" oninput="maskCpfCnpj(this)" maxlength="14">
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label>Telefone</label>
                                <input type="text" name="telefone" class="form-control" value="<%= (typeof vendedor !== 'undefined' && vendedor) ? (vendedor.telefone || '') : '' %>" oninput="maskTelefone(this)" maxlength="15">
                            </div>
                            <div class="form-group">
                                <label>Email</label>
                                <input type="email" name="email" class="form-control" value="<%= (typeof vendedor !== 'undefined' && vendedor) ? (vendedor.email || '') : '' %>">
                            </div>
                        </div>

                        <div class="form-row-3">
                            <div class="form-group">
                                <label>Comissao (%)</label>
                                <input type="number" name="comissao_percentual" class="form-control" value="<%= (typeof vendedor !== 'undefined' && vendedor) ? vendedor.comissao_percentual : '5' %>" min="0" max="100" step="0.01">
                            </div>
                            <div class="form-group">
                                <label>Meta Mensal (R$)</label>
                                <input type="number" name="meta_mensal" class="form-control" value="<%= (typeof vendedor !== 'undefined' && vendedor) ? vendedor.meta_mensal : '0' %>" min="0" step="0.01">
                            </div>
                            <div class="form-group">
                                <label>Status</label>
                                <div style="padding-top: 8px;">
                                    <label style="display: flex; align-items: center; gap: 8px; cursor: pointer; font-weight: normal;">
                                        <input type="checkbox" name="ativo" value="1" <%= (typeof vendedor === 'undefined' || !vendedor || vendedor.ativo) ? 'checked' : '' %> style="width: 18px; height: 18px;">
                                        Ativo
                                    </label>
                                </div>
                            </div>
                        </div>

                        <div class="btn-group" style="margin-top: 16px; justify-content: flex-end;">
                            <a href="/vendedores" class="btn btn-secondary">Cancelar</a>
                            <button type="submit" class="btn btn-primary">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
                                <%= (typeof vendedor !== 'undefined' && vendedor && vendedor.id) ? 'Salvar Alteracoes' : 'Cadastrar Vendedor' %>
                            </button>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>
<script src="/js/app.js"></script>
</body>
</html>

# ─── Montana Multi-Empresa — Variáveis de Ambiente ────────────────────────────
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o arquivo .env no git.

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=3002
NODE_ENV=production

# ─── Autenticação JWT ─────────────────────────────────────────────────────────
# Gere uma string aleatória segura: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=troque_por_string_aleatoria_longa
JWT_EXPIRES=8h

# ─── Credenciais de acesso ────────────────────────────────────────────────────
ADMIN_SENHA=troque_a_senha_admin
FINANCEIRO_SENHA=troque_a_senha_financeiro

# ─── WebISS / NFS-e Palmas-TO ─────────────────────────────────────────────────
WEBISS_URL=https://palmasto.webiss.com.br/ws/nfse.asmx

# Credenciais do portal WebISS por empresa
WEBISS_LOGIN_ASSESSORIA=
WEBISS_SENHA_ASSESSORIA=
WEBISS_LOGIN_SEGURANCA=
WEBISS_SENHA_SEGURANCA=
WEBISS_LOGIN_PORTODOVAU=
WEBISS_SENHA_PORTODOVAU=
WEBISS_LOGIN_MUSTANG=
WEBISS_SENHA_MUSTANG=

# Inscrição Municipal no Município de Palmas
WEBISS_INSC_ASSESSORIA=
WEBISS_INSC_SEGURANCA=
WEBISS_INSC_PORTODOVAU=
WEBISS_INSC_MUSTANG=

# Senha dos certificados A1 (.pfx) — necessária apenas para EMISSÃO de NFS-e
WEBISS_CERT_SENHA_ASSESSORIA=
WEBISS_CERT_SENHA_SEGURANCA=
WEBISS_CERT_SENHA_PORTODOVAU=
WEBISS_CERT_SENHA_MUSTANG=

# ─── MCPs (Montana Cloud + Montana Intelligence) ──────────────────────────────
# Token único do dev/cliente para conectar nos MCPs (formato: tok_<random>)
MONTANA_TOKEN=

# No SERVIDOR (não no cliente): mapa de tokens -> labels para auth Bearer.
# Gerar cada token: python3 -c "import secrets; print('tok_'+secrets.token_urlsafe(32))"
# Exemplo: {"tok_abc...":"claude-code-felipe","tok_def...":"antigravity-shared"}
MONTANA_TOKENS_JSON=

# Bind interface (servidor) — manter 127.0.0.1 atrás de Caddy/Nginx com TLS
MCP_HOST=127.0.0.1
MCP_PORT=3010
MONTANA_HOST=127.0.0.1

# Path do audit log (servidor)
MCP_AUDIT_LOG=/opt/montana/logs/mcp_audit.jsonl

# ─── E-mail (notificações automáticas) ────────────────────────────────────────
# Opcional — deixar em branco para desativar notificações
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_TO=
